<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <p>Here are a few of our partner organizations:</p>

        <ul class="images">
            <% organizations.forEach(org=> { %>
                <li>
                    <img src="/image/<%= org.logo_filename %>" alt="<%= org.name %> logo">
                    <strong>
                        <%= org.name %>
                    </strong>: <%= org.contact_email %>
                </li>
                <% }); %>
        </ul>
    </main>
    <%- include('partials/footer') %>
